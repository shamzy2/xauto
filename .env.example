# Public canonical URL (ingen avsluttende slash). Påkrevd i produksjon for riktige OG-lenker, sitemap og robots.
# NEXT_PUBLIC_SITE_URL=https://www.xbilsenter.no

# Copy to `.env.local` for local development.
# Never commit `.env.local` or paste real keys into chat.
#
# If `vercel dev` says a secret is missing but `.env.local` has it: in the Vercel project,
# either add the variable for the "Development" environment, or remove a placeholder entry
# that sets the same name to an empty value (empty values block `.env.local` overrides).
#
# `vercel env pull` overwrites `.env.local` — re-add app-only vars after pull, or define them
# in Vercel so they get pulled too (recommended for INTAKE_VIEW_SECRET + EXTERNAL_API_KEY).

# Statens vegvesen — enkeltoppslag (header: SVV-Authorization: Apikey …)
# See app/api/sell/intake/route.ts
EXTERNAL_API_KEY=

# Optional — e.g. HMAC secret for inbound webhooks
CRM_WEBHOOK_SECRET=

# Required for /selg/steg-2 — signs HttpOnly cookie so intake URLs are not shareable
INTAKE_VIEW_SECRET=

# Supabase (Vercel integration / `vercel env pull`) — admin panel + lagring av innsendinger
# Kjør også SQL i supabase/migrations mot prosjektet (tabell sell_submissions, innbytte_submissions, bucket sell-submission-photos).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   # or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# SUPABASE_SERVICE_ROLE_KEY=       # server-only: API for innsending + storage uploads (må være service role, ikke anon)
